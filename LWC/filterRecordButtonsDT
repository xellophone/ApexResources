-------------------------------------------------
// HTML
-------------------------------------------------
<template>
    <lightning-card title="Filter Records with button" icon-name="standard:account">
        
        <div slot="actions">
            <lightning-button label="Refresh" icon-name="utility:refresh" onclick={handleRefresh} class="slds-m-right_x-small"></lightning-button>
            <lightning-button label="Add Account" icon-name="utility:add" variant="brand" onclick={openStandardNewRecordPage}></lightning-button>
        </div>

        <div class="slds-m-around_medium">
            <div class="slds-m-bottom_medium">
                <span class="slds-m-right_small slds-text-title_bold">Filter by Industry:</span>
                <lightning-button-group>
                    <lightning-button 
                        label="All" 
                        variant={allButtonVariant}
                        data-industry="" 
                        onclick={handleIndustryFilter}>
                    </lightning-button>
                    <lightning-button 
                        label="Banking" 
                        variant={bankingButtonVariant}
                        data-industry="Banking" 
                        onclick={handleIndustryFilter}>
                    </lightning-button>
                    <lightning-button 
                        label="Technology" 
                        variant={techButtonVariant}
                        data-industry="Technology" 
                        onclick={handleIndustryFilter}>
                    </lightning-button>
                    <lightning-button 
                        label="Energy" 
                        variant={energyButtonVariant}
                        data-industry="Energy" 
                        onclick={handleIndustryFilter}>
                    </lightning-button>
                </lightning-button-group>
            </div>

            <template if:true={accounts.length}>
                <div style="height: 300px;">
                    <lightning-datatable
                        key-field="Id"
                        data={accounts}
                        columns={columns}
                        hide-checkbox-column>
                    </lightning-datatable>
                </div>
            </template>

            <template if:true={error}>
                <div class="slds-text-color_error">Error loading data.</div>
            </template>

            <div class="slds-m-top_medium slds-grid slds-grid_align-center slds-grid_vertical-align-center">
                <div class="slds-button-group" role="group">
                    <button class="slds-button slds-button_neutral" onclick={handlePrevious} disabled={isFirstPage}>Previous</button>

                    <template for:each={visiblePages} for:item="page">
                        <template if:true={page.isPage}>
                            <button key={page.label} data-page={page.label} onclick={handlePageClick} style="font-weight: bold;" class="slds-button slds-button_neutral theme-page-btn" disabled={page.active}>
                                {page.label}
                            </button>
                        </template>
                        <template if:false={page.isPage}>
                            <span key={page.label} class="slds-p-horizontal_small slds-align-middle">{page.label}</span>
                        </template>
                    </template>

                    <button class="slds-button slds-button_neutral" onclick={handleNext} disabled={isLastPage}>Next</button>
                </div>
            </div>
            
            <div class="slds-text-align_center slds-m-top_x-small slds-text-color_weak">
                Page {pageNumber} of {totalPages} (Total Records: {totalCount})
            </div>
        </div>
    </lightning-card>
</template>
