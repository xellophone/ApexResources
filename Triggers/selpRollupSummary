// Trigger ........................................
trigger AccountRollupTrigger on Account (
    after insert,
    after update,
    after delete,
    after undelete
) {

    Set<Id> affectedParents = new Set<Id>();

    if (Trigger.isInsert || Trigger.isUpdate || Trigger.isUndelete) {
        for (Account acc : Trigger.new) {
            if (acc.ParentId != null) {
                affectedParents.add(acc.ParentId);
            }
        }
    }

    if (Trigger.isUpdate) {
        for (Account acc : Trigger.new) {
            Account oldAcc = Trigger.oldMap.get(acc.Id);

            // Reparenting case
            if (oldAcc.ParentId != acc.ParentId) {
                if (oldAcc.ParentId != null) affectedParents.add(oldAcc.ParentId);
                if (acc.ParentId != null) affectedParents.add(acc.ParentId);
            }
        }
    }

    if (Trigger.isDelete) {
        for (Account acc : Trigger.old) {
            if (acc.ParentId != null) {
                affectedParents.add(acc.ParentId);
            }
        }
    }

    if (!affectedParents.isEmpty()) {
        AccountRollupHelper.recalculateAll(affectedParents);
    }
}


// Helper ......................................................................

public class AccountRollupHelper {

    public static void recalculateAll(Set<Id> startParents) {

        Set<Id> toProcess = new Set<Id>(startParents);
        Set<Id> processed = new Set<Id>();

        while (!toProcess.isEmpty()) {

            Set<Id> currentBatch = new Set<Id>();
            currentBatch.addAll(toProcess);
            toProcess.clear();

            // Aggregate children sums
            Map<Id, Decimal> rollupMap = new Map<Id, Decimal>();

            for (AggregateResult ar : [
                SELECT ParentId pId, SUM(Amount__c) total
                FROM Account
                WHERE ParentId IN :currentBatch
                GROUP BY ParentId
            ]) {
                rollupMap.put((Id)ar.get('pId'), (Decimal)ar.get('total'));
            }

            List<Account> updates = new List<Account>();

            for (Id parentId : currentBatch) {

                Decimal total = rollupMap.containsKey(parentId)
                    ? rollupMap.get(parentId)
                    : 0;

                updates.add(new Account(
                    Id = parentId,
                    Total_Amount__c = total
                ));

                processed.add(parentId);
            }

            if (!updates.isEmpty()) {
                update updates;
            }

            // Move upward (grandparents)
            Set<Id> nextParents = new Set<Id>();

            for (Account acc : [
                SELECT Id, ParentId
                FROM Account
                WHERE Id IN :currentBatch
            ]) {
                if (acc.ParentId != null && !processed.contains(acc.ParentId)) {
                    nextParents.add(acc.ParentId);
                }
            }

            toProcess.addAll(nextParents);
        }
    }
}


