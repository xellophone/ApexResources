# 2. Generate PDF from Apex

 
    @future(callout=true)
    public static void sendWelcomeEmailWithPDF(Set<Id> contactIds) {
        // Query the inserted contacts (Make sure to query the Email field!)
        List<Contact> contacts = [
            SELECT Id, FirstName, LastName, Email 
            FROM Contact 
            WHERE Id IN :contactIds AND Email != null
        ];
        
        if (contacts.isEmpty()) return;
        
        List<Messaging.SingleEmailMessage> emailsToSend = new List<Messaging.SingleEmailMessage>();
        
        for (Contact con : contacts) {
            // Reference the correct Contact Visualforce page
            PageReference pdfPage = Page.AccountPDFPage;
            pdfPage.getParameters().put('id', con.Id);
            
            Blob pdfBlob;
            
            try {
                // getContentAsPDF() cannot be called in Test Context
                if (!Test.isRunningTest()) {
                    pdfBlob = pdfPage.getContentAsPDF();
                } else {
                    pdfBlob = Blob.valueOf('Mock PDF content for test class');
                }
            } catch (Exception e) {
                System.debug('Error generating PDF: ' + e.getMessage());
                continue; // Skip this contact if PDF generation fails
            }
            
            // 1. Create the File Attachment
            Messaging.EmailFileAttachment attachment = new Messaging.EmailFileAttachment();
            attachment.setFileName('Welcome_' + con.FirstName + '_' + con.LastName + '.pdf');
            attachment.setBody(pdfBlob);
            attachment.setContentType('application/pdf');
            
            // 2. Draft the Email Message
            Messaging.SingleEmailMessage email = new Messaging.SingleEmailMessage();
            email.setToAddresses(new List<String>{ con.Email }); // Sending to the Contact's email
            email.setSubject('Welcome to Our Company, ' + con.FirstName + '!');
            email.setPlainTextBody(
                'Hi ' + con.FirstName + ',\n\n' +
                'We are thrilled to have you! Please find your automatically generated welcome document attached to this email.\n\n' +
                'Best Regards,\n' +
                'The Team'
            );
            email.setFileAttachments(new List<Messaging.EmailFileAttachment>{ attachment });
            
            emailsToSend.add(email);
        }
        
        // 3. Send all emails at once
        if (!emailsToSend.isEmpty()) {
            Messaging.sendEmail(emailsToSend, false);
        }
        
    }


