trigger ContactTrigger on Contact (after insert) {
    
    // Consolidate into a single block
    if(Trigger.isAfter && Trigger.isInsert){
        
        // 1. Loop through contacts to find valid phone numbers
        for (Contact newContact : Trigger.new) {
            
            if (String.isNotBlank(newContact.MobilePhone)) {
                // Invoke the future method from your class
                TwilioSMSController.sendWelcomeSMS(newContact.MobilePhone, newContact.FirstName);
            }
        }
    }
}
